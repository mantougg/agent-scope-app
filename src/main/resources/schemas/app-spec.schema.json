{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "label", "type"],
  "properties": {
    "name":  { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9]*$" },
    "label": { "type": "string", "minLength": 1 },
    "type":  { "type": "string", "minLength": 1 }
  }
}